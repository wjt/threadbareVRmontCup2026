[resource]
script = ExtResource("1_qxsdu")
title = "Bill the Pill and the Norse gods"
description = "Bill is a pill. One day, he somehow finds himself in Valhalla. The Norse gods are infected with a cold. But not just any cold! A cold that can only be healed by a blanket made of the threads of Memory, Imagination, and Spirit. Bill sets off on a daring quest to collect the threads. Who and What will he encounter?!"
authors = Array[String](["Stellan Shutter", "Cian Shutter"])
first_scene = "uid://dvtsxw4ib6v1d"
sprite_frames = SubResource("SpriteFrames_mwofu")
animation_name = &"default"
metadata/_custom_type_script = "uid://dts1hwdy3phin"
